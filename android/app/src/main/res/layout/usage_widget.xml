<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_container"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="16dp"
  android:background="@drawable/widget_background_material"
>
  <!-- Header -->
  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginBottom="12dp"
  >
    <TextView
      android:id="@+id/widget_title"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="Screen Time"
      android:textSize="13sp"
      android:textStyle="bold"
      android:textColor="@color/widget_on_surface_variant"
      android:letterSpacing="0.05"
    />
    <ImageButton
      android:id="@+id/refresh_button"
      android:layout_width="20dp"
      android:layout_height="20dp"
      android:src="@drawable/ic_refresh"
      android:background="?android:attr/selectableItemBackgroundBorderless"
      android:contentDescription="Refresh"
      android:scaleType="fitCenter"
      android:tint="@color/widget_on_surface_variant"
    />
  </LinearLayout>

  <!-- Total time -->
  <TextView
    android:id="@+id/total_time"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="0h 0m"
    android:textSize="32sp"
    android:textStyle="bold"
    android:textColor="@color/widget_on_surface"
    android:layout_marginBottom="16dp"
    android:letterSpacing="-0.02"
  />

  <!-- App 1 -->
  <LinearLayout
    android:id="@+id/app1_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="5dp"
    android:paddingBottom="5dp"
  >
    <ImageView
      android:id="@+id/app1_icon"
      android:layout_width="26dp"
      android:layout_height="26dp"
      android:src="@android:drawable/sym_def_app_icon"
    />
    <TextView
      android:id="@+id/app1_name"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginStart="10dp"
      android:text="App 1"
      android:textSize="13sp"
      android:textColor="@color/widget_on_surface"
      android:maxLines="1"
      android:ellipsize="end"
    />
    <TextView
      android:id="@+id/app1_time"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="0m"
      android:textSize="12sp"
      android:textColor="@color/widget_on_surface_variant"
      android:layout_marginStart="8dp"
    />
  </LinearLayout>

  <!-- App 2 -->
  <LinearLayout
    android:id="@+id/app2_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="5dp"
    android:paddingBottom="5dp"
  >
    <ImageView
      android:id="@+id/app2_icon"
      android:layout_width="26dp"
      android:layout_height="26dp"
      android:src="@android:drawable/sym_def_app_icon"
    />
    <TextView
      android:id="@+id/app2_name"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginStart="10dp"
      android:text="App 2"
      android:textSize="13sp"
      android:textColor="@color/widget_on_surface"
      android:maxLines="1"
      android:ellipsize="end"
    />
    <TextView
      android:id="@+id/app2_time"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="0m"
      android:textSize="12sp"
      android:textColor="@color/widget_on_surface_variant"
      android:layout_marginStart="8dp"
    />
  </LinearLayout>

  <!-- App 3 -->
  <LinearLayout
    android:id="@+id/app3_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="5dp"
    android:paddingBottom="5dp"
  >
    <ImageView
      android:id="@+id/app3_icon"
      android:layout_width="26dp"
      android:layout_height="26dp"
      android:src="@android:drawable/sym_def_app_icon"
    />
    <TextView
      android:id="@+id/app3_name"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginStart="10dp"
      android:text="App 3"
      android:textSize="13sp"
      android:textColor="@color/widget_on_surface"
      android:maxLines="1"
      android:ellipsize="end"
    />
    <TextView
      android:id="@+id/app3_time"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="0m"
      android:textSize="12sp"
      android:textColor="@color/widget_on_surface_variant"
      android:layout_marginStart="8dp"
    />
  </LinearLayout>
  
  <!-- App 4 -->
  <LinearLayout
    android:id="@+id/app4_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="5dp"
    android:paddingBottom="5dp"
  >
    <ImageView
      android:id="@+id/app4_icon"
      android:layout_width="26dp"
      android:layout_height="26dp"
      android:src="@android:drawable/sym_def_app_icon"
    />
    <TextView
      android:id="@+id/app4_name"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginStart="10dp"
      android:text="App 4"
      android:textSize="13sp"
      android:textColor="@color/widget_on_surface"
      android:maxLines="1"
      android:ellipsize="end"
    />
    <TextView
      android:id="@+id/app4_time"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="0m"
      android:textSize="12sp"
      android:textColor="@color/widget_on_surface_variant"
      android:layout_marginStart="8dp"
    />
  </LinearLayout>
</LinearLayout>
